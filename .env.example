# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a long random string: `openssl rand -base64 32`
JWT_SECRET="replace-with-a-long-random-secret"

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Email (optional for local dev) ──────────────────────────────────────────
# Leave everything blank to skip sending emails (they'll be logged to the
# console instead). Two ways to enable real sending:
#
# Option 1 — Resend (requires a verified domain):
RESEND_API_KEY=""
#
# Option 2 — Any SMTP provider, e.g. Gmail with an App Password (no domain
# needed). Ignored if RESEND_API_KEY is set.
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
#
# Sender address. For Gmail SMTP this must be your Gmail address.
EMAIL_FROM="noreply@asianahub.com"

# ─── Security (optional — these are the defaults) ────────────────────────────
MAX_LOGIN_ATTEMPTS=5
RESET_TOKEN_EXPIRY_MINUTES=60
