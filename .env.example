# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a long random string: `openssl rand -base64 32`
JWT_SECRET="replace-with-a-long-random-secret"

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Email (optional for local dev) ──────────────────────────────────────────
# Leave blank to skip sending emails (they'll be logged to the console instead)
RESEND_API_KEY=""
EMAIL_FROM="noreply@advancehub.com"

# ─── Security (optional — these are the defaults) ────────────────────────────
MAX_LOGIN_ATTEMPTS=5
RESET_TOKEN_EXPIRY_MINUTES=60
