// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int       @id @default(autoincrement())
  name                 String
  email                String    @unique
  passwordHash         String
  role                 String    @default("pending") // pending_approval | requester | approver | admin
  status               String    @default("pending_approval") // pending_approval | active | deactivated
  failedLoginAttempts  Int       @default(0)
  lockedAt             DateTime?
  mustChangePassword   Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  submittedRequests    AdvanceRequest[] @relation("RequesterRelation")
  attendedRequests     AdvanceRequest[] @relation("AttendedByRelation")
  returnedRequests     AdvanceRequest[] @relation("ReturnedByRelation")
  deletedRequests      AdvanceRequest[] @relation("DeletedByRelation")
  studentsCreated      Student[]        @relation("StudentCreatedBy")
  studentsUpdated      Student[]        @relation("StudentUpdatedBy")
  auditLogs            AuditLog[]
  passwordResetTokens  PasswordResetToken[]
  workdayUploads       WorkdayRecord[]  @relation("WorkdayUploadedBy")
}

model Student {
  id        Int      @id @default(autoincrement())
  icNumber  String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdBy Int?
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator  User? @relation("StudentCreatedBy", fields: [createdBy], references: [id])
  updater  User? @relation("StudentUpdatedBy", fields: [updatedBy], references: [id])

  requests AdvanceRequest[]
  workdayRecord WorkdayRecord?
}

model AdvanceRequest {
  id          Int       @id @default(autoincrement())
  studentId   Int
  requesterId Int
  amount      Int       // whole numbers only, in RM
  frequency   Int       // auto-calculated
  status      String    @default("pending") // pending | completed | deleted
  comment     String?   // approver/admin note added at approval or deletion
  remark      String?   // optional note from the requester at submission

  // attendedBy/attendedAt and returnedBy/returnedAt are both set to the
  // approver at approval time (approval immediately completes the request).
  attendedBy  Int?
  attendedAt  DateTime?
  returnedBy  Int?
  returnedAt  DateTime?
  deletedBy   Int?
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  student     Student  @relation(fields: [studentId], references: [id])
  requester   User     @relation("RequesterRelation", fields: [requesterId], references: [id])
  attendedByUser User? @relation("AttendedByRelation", fields: [attendedBy], references: [id])
  returnedByUser User? @relation("ReturnedByRelation", fields: [returnedBy], references: [id])
  deletedByUser  User? @relation("DeletedByRelation", fields: [deletedBy], references: [id])

  @@index([status])
  @@index([studentId])
  @@index([requesterId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String   // REQUEST_CREATED | REQUEST_APPROVED | APPROVED_DATE_UPDATED | REQUEST_DELETED | ACCOUNT_APPROVED | PASSWORD_RESET | STUDENT_CREATED | STUDENT_UPDATED | USER_DEACTIVATED | WORKDAY_CSV_IMPORTED | WORKDAY_SETTINGS_UPDATED | EMPLOYER_GROUP_CREATED | EMPLOYER_GROUP_UPDATED | EMPLOYER_GROUP_DELETED
  entityType String   // request | student | user | workday
  entityId   Int?
  metadata   String?  // JSON string
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ── Workday Tracking module ────────────────────────────────────────────────

// An employer that provides internship workdays. Each group has its own
// monthly cutoff day; an uploaded CSV reflects workdays only up to that day.
model EmployerGroup {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  cutoffDay Int      // day of month (1-31) the group's data is current up to
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records WorkdayRecord[]
}

// Global, admin-editable settings for the estimation engine. Single row.
model WorkdaySettings {
  id               Int      @id @default(autoincrement())
  workdaysPerWeek  Int      @default(6)
  requiredWorkdays Int      @default(0)
  updatedBy        Int?
  updatedAt        DateTime @updatedAt
}

// One current snapshot per student. Each CSV upload overwrites the running
// cumulative total (no history kept). The total is accurate as of the
// student's employer-group cutoff day within the data month (dataYear/dataMonth).
model WorkdayRecord {
  id                 Int      @id @default(autoincrement())
  studentId          Int      @unique
  employerGroupId    Int
  cumulativeWorkdays Int      // floored whole days
  dataYear           Int      // year of the data month (the T-1 month)
  dataMonth          Int      // 1-12, the data month
  uploadedBy         Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  student       Student       @relation(fields: [studentId], references: [id])
  employerGroup EmployerGroup @relation(fields: [employerGroupId], references: [id])
  uploader      User?         @relation("WorkdayUploadedBy", fields: [uploadedBy], references: [id])

  @@index([employerGroupId])
}
